# ═══════════════════════════════════════════════════════════════
#  RAHMAT DNS SaaS — Server Setup Configuration
#
#  How to use:
#    Local clone :  cp .env.example .env && nano .env && sudo bash setup.sh
#    Remote host :  sudo mkdir -p /etc/rahmat
#                   sudo nano /etc/rahmat/.env   # paste & edit this file
#                   curl -fsSL …/setup.sh | sudo bash
#
#  Edit order (top = most important):
#    1. SSH  2. Fail2Ban  3. DDoS rate limits  4. General & DNS stack tuning
#
#  Load order (later wins):  /etc/rahmat/.env  →  ./.env  →  defaults
#  DDoS-only reload:         systemctl restart rahmat-ddos
# ═══════════════════════════════════════════════════════════════

# ── SSH hardening (setup phase 10) ──────────────────────────────
# Writes /etc/ssh/sshd_config.d/99-rahmat.conf and may restrict firewalld.
# *** EDIT THIS SECTION FIRST — setup does not prompt for keys or IPs ***
#
# PRODUCTION MINIMUM (set all four):
#   SSH_PUBLIC_KEY="ssh-rsa  imzami"
#   SSH_WHITELIST_IPS="103.179.24.69/32"
#   SSH_OPEN_PUBLIC="false"
#   SSH_DISABLE_PASSWORD="yes"

# TCP port sshd listens on (must match firewalld if you change it)
SSH_PORT="22"

# Only this Linux user may SSH in (AllowUsers in sshd)
SSH_USER="root"

# Your SSH public key, one full line (ssh-ed25519 / ssh-rsa / ecdsa).
# REQUIRED — setup reads this from .env only (no phase-10 prompts).
# Empty = no key installed; root password login kept enabled so you are not locked out.
SSH_PUBLIC_KEY=""

# Comma-separated source IPs/CIDRs allowed to reach SSH (firewalld rich rules).
# REQUIRED for production — port 22 is NOT open to the world unless you opt in below.
# Example: "203.0.113.10/32,198.51.100.0/24"
# Empty + connected via SSH = setup auto-allows your current IP only.
# Empty + VPS console only = SSH blocked until you set this and re-run setup.
SSH_WHITELIST_IPS=""

# false = block SSH unless SSH_WHITELIST_IPS (or auto-detected session IP) allows it
# true  = open SSH_PORT to all IPs (legacy / staging only — not recommended)
SSH_OPEN_PUBLIC="false"

# Password login for SSH:
#   auto = disable passwords only when SSH_PUBLIC_KEY is set (recommended)
#   yes  = always allow password login
#   no   = key-only; fails if SSH_PUBLIC_KEY is empty
SSH_DISABLE_PASSWORD="auto"

# Max failed auth attempts per connection before disconnect
SSH_MAX_AUTH_TRIES="3"

# Seconds to complete authentication before sshd drops the connection
SSH_LOGIN_GRACE_TIME="30"

# Keepalive: send probe every N seconds; disconnect after COUNT_MAX missed replies
SSH_CLIENT_ALIVE_INTERVAL="300"
SSH_CLIENT_ALIVE_COUNT_MAX="2"

# ── Fail2Ban (setup phase 11) ───────────────────────────────────
# Bans IPs after repeated failed SSH logins (firewalld rich-rule banaction).

# Default jail settings (all jails unless overridden below)
F2B_DEFAULT_BANTIME="3600"
F2B_DEFAULT_FINDTIME="600"
F2B_DEFAULT_MAXRETRY="3"

# sshd jail — aggressive mode, very low retry tolerance
F2B_SSHD_MAXRETRY="2"
F2B_SSHD_BANTIME="86400"
F2B_SSHD_FINDTIME="300"
F2B_SSHD_MODE="aggressive"

# recidive jail — re-bans repeat offenders for longer
F2B_RECIDIVE_BANTIME="604800"
F2B_RECIDIVE_FINDTIME="86400"
F2B_RECIDIVE_MAXRETRY="2"

# ── DDoS rate limits (setup phase 9) ────────────────────────────
# iptables/firewalld rules that throttle abusive query floods.
# Synced to /etc/rahmat/ddos.conf — restart rahmat-ddos after edits.

# DNS plain UDP/TCP (port 53)
DNS_UDP_RATE="300/sec"
DNS_UDP_BURST="600"
DNS_TCP_RATE="50/sec"
DNS_TCP_BURST="100"
DNS_TCP_CONN_MAX="30"
DNS_UDP_MAX_PACKET="1232"

# DoT — DNS-over-TLS (port 853)
DOT_RATE="200/sec"
DOT_BURST="400"
DOT_CONN_MAX="500"

# DoH — DNS-over-HTTPS (port 443)
DOH_RATE="80/sec"
DOH_BURST="160"

# Global SYN flood ceiling (all services)
SYN_RATE="2000/sec"
SYN_BURST="4000"

# ── Firewall service ports (informational — opened by setup) ─────
# These document which ports firewalld opens; change SSH_PORT if you move SSH
FW_PORT_SSH="22"
FW_PORT_DNS_UDP="53"
FW_PORT_DNS_TCP="53"
FW_PORT_DOT="853"
FW_PORT_HTTP="80"
FW_PORT_HTTPS="443"

# ── General ─────────────────────────────────────────────────────

# Link shown in setup summary (informational only)
GITHUB_URL="https://github.com/zamibd/setup/setup.sh"

# System timezone (timedatectl)
TIMEZONE="Asia/Dhaka"

# true  = optional prompts (e.g. swap creation) when stdin is a TTY
# false = never prompt; rely only on values in this file
INTERACTIVE_PROMPTS="true"

# ── Upstream DNS (written to /etc/resolv.conf) ──────────────────
# Resolvers the host uses for outbound lookups (not your SaaS DNS service)
DNS_NAMESERVER_1="8.8.8.8"
DNS_NAMESERVER_2="1.1.1.1"
DNS_NAMESERVER_3="8.8.4.4"

# ── Swap ────────────────────────────────────────────────────────
# Extra virtual memory file; helps under memory pressure on small VPS plans
SWAP_ENABLED="true"
SWAP_SIZE_GB="2"
SWAP_FILE="/swapfile"

# ── File descriptor limits ────────────────────────────────────────
# Raised limits for high-connection DNS workloads (/etc/security/limits.d)
LIMIT_NOFILE="1048576"
LIMIT_NPROC="65535"

# ── Kernel tuning (DNS 53 / DoT 853) ────────────────────────────
# Network stack sizing for many concurrent UDP/TCP DNS connections
SYSCTL_NETDEV_MAX_BACKLOG="250000"
SYSCTL_NETDEV_BUDGET="1200"
SYSCTL_NETDEV_BUDGET_USECS="16000"
SYSCTL_SOMAXCONN="65535"
SYSCTL_CONNTRACK_MAX="2097152"
SYSCTL_CONNTRACK_TCP_ESTABLISHED="7200"
SYSCTL_SWAPPINESS="10"
SYSCTL_FILE_MAX="2097152"
SYSCTL_UDP_RMEM_MIN="16384"

# true = enable TCP BBR congestion control (better throughput on lossy links)
TCP_BBR_ENABLED="true"

# ── Performance & advanced hardening (setup phase 15) ───────────
PERF_THP_DISABLE="true"
PERF_CPU_GOVERNOR="true"
HARDEN_CHRONY="true"
HARDEN_AUDITD="true"
HARDEN_DISABLE_UNUSED_SERVICES="true"

# ── Docker ──────────────────────────────────────────────────────
# Container runtime installed and tuned for DNS stack deployment
DOCKER_LOG_MAX_SIZE="10m"
DOCKER_LOG_MAX_FILE="3"
DOCKER_STORAGE_DRIVER="overlay2"
DOCKER_CGROUP_DRIVER="systemd"
